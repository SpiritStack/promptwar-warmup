# VisualLink — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Options: gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# ── Google Cloud Platform ─────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=visuallink-media

# Path to your GCP service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

# ── Google Workspace ──────────────────────────────────────────────────────────
# The user to impersonate (must have Workspace admin / domain-wide delegation)
GOOGLE_WORKSPACE_DELEGATED_USER=admin@yourdomain.com

# Gmail: address that sends all notification emails
NOTIFICATION_SENDER_EMAIL=alerts@yourdomain.com

# Case worker who receives Calendar invites
CASE_WORKER_EMAIL=caseworker@yourdomain.com

# Google Sheets — ID of the audit log spreadsheet (from the URL)
AUDIT_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
